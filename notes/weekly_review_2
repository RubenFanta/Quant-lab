Correction 2 — Create src/risk_metrics.py

You need reusable functions immediately.

import numpy as np
import pandas as pd


def simple_returns(prices: pd.Series) -> pd.Series:
    return prices.pct_change()


def log_returns(prices: pd.Series) -> pd.Series:
    return np.log(prices / prices.shift(1))


def cumulative_returns(returns: pd.Series) -> pd.Series:
    return (1 + returns).cumprod() - 1


def annualized_volatility(returns: pd.Series, periods_per_year: int = 252) -> float:
    return returns.std() * np.sqrt(periods_per_year)


def drawdown(equity_curve: pd.Series) -> pd.Series:
    running_peak = equity_curve.cummax()
    return equity_curve / running_peak - 1


def max_drawdown(equity_curve: pd.Series) -> float:
    return drawdown(equity_curve).min()

Then import these functions inside notebooks.

